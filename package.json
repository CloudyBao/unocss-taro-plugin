{
  "name": "unocss-taro-plugin",
  "version": "0.1.6",
  "description": "Taro plugin for integrating UnoCSS in webpack/postcss pipelines",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts && cp src/postcss-unocss.cjs dist/postcss-unocss.cjs",
    "clean": "rimraf dist"
  },
  "keywords": [
    "taro",
    "webpack",
    "unocss",
    "plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@tarojs/cli": ">=4.0.0",
    "unocss": ">=66.0.0",
    "@unocss/postcss": ">=66.0.0",
    "@unocss/webpack": ">=66.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@unocss/postcss": "^66.6.7",
    "@unocss/webpack": "^66.6.7",
    "rimraf": "^6.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/CloudyBao/unocss-taro-plugin.git"
  },
  "homepage": "https://github.com/CloudyBao/unocss-taro-plugin#readme",
  "bugs": {
    "url": "https://github.com/CloudyBao/unocss-taro-plugin/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
